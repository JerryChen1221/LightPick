{
  "name": "@lightpick/bridge",
  "version": "0.1.0-beta.30",
  "description": "LightPick bridge — pair a local Claude Code (or other ACP agent) with the LightPick web UI.",
  "private": true,
  "type": "module",
  "bin": {
    "lightpick-bridge": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup && pnpm bundle:crew",
    "bundle:crew": "node scripts/bundle-crew.mjs",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.20.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.0"
  }
}
