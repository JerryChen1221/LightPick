# Custom response headers for Cloudflare Workers Static Assets.
# https://developers.cloudflare.com/workers/static-assets/headers/
#
# Vite copies everything in public/ to dist/client/ during build, and the
# CF static-assets layer reads dist/client/_headers automatically.

# Hashed Vite chunks live under /_app/ — filename contains a content hash
# so the URL changes whenever the bytes change. Safe to cache forever in
# the browser (immutable). Without this, CF defaults to
# `Cache-Control: public, max-age=0, must-revalidate`, which forces every
# reload to round-trip a 304 check for every chunk — a killer over a
# slow / cross-region link.
/_app/*
  Cache-Control: public, max-age=31536000, immutable

# Same for fingerprintless static-served assets we never rotate.
/favicon.svg
  Cache-Control: public, max-age=86400
